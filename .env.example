# База данных PostgreSQL.
# На этапе 1 получим бесплатную облачную базу командой `npx create-db`
# и подставим сюда её строку подключения.
DATABASE_URL="postgresql://user:pass@localhost:5432/vizual?schema=public"

# Ключ доступа к CRM Topnlab (выдают сотрудники Topnlab). Нужен на этапе 7.
TOPNLAB_KEY="заменить-на-реальный-ключ"
TOPNLAB_BASE_URL="https://agencies-p.topnlab.ru"

# Публичный адрес сайта — для sitemap, robots и ссылок в соцсетях.
# На Railway укажем боевой домен.
SITE_URL="http://localhost:3000"
